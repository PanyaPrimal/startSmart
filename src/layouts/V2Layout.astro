---
import VersionSwitcher from '../components/VersionSwitcher.astro';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="uk" data-v="v2">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — StartSmart</title>
  {description && <meta name="description" content={description} />}
  <script is:inline>
    (function () {
      try {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      } catch (e) {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..900,0..100&family=Geist:wght@300..700&display=swap"
    rel="stylesheet"
  />
</head>
<body class="v2-body">
  <slot />
  <VersionSwitcher />

  <script is:inline>
    // Scroll-reveal: add .is-in when element enters viewport
    (function () {
      if (!('IntersectionObserver' in window)) {
        document.querySelectorAll('[data-reveal]').forEach((el) => el.classList.add('is-in'));
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
    })();

    // Simple accordion
    document.querySelectorAll('[data-accordion] > [data-accordion-item]').forEach((item) => {
      const btn = item.querySelector('[data-accordion-trigger]');
      if (!btn) return;
      btn.addEventListener('click', () => {
        item.classList.toggle('is-open');
      });
    });

    // Theme toggle for v2
    const v2ThemeBtn = document.getElementById('v2ThemeToggle');
    if (v2ThemeBtn) {
      v2ThemeBtn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme') || 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch (e) {}
      });
    }
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      if (!localStorage.getItem('theme')) {
        document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
      }
    });
  </script>

  <style is:global>
    /* ============================================================
       V2 — Editorial / Literary Magazine theme
       Scoped via [data-v="v2"] on <html>. Does NOT touch v1 styles.
       ============================================================ */

    :root[data-v="v2"] {
      /* Paper palette — light */
      --paper:        #F4EFE6;
      --paper-2:      #EDE6D7;
      --ink:          #14110E;
      --ink-soft:     #5A544A;
      --ink-faint:    #9A928A;
      --rule:         rgba(20, 17, 14, 0.14);
      --rule-strong:  rgba(20, 17, 14, 0.32);
      --accent:       #C1432B;      /* vermilion */
      --accent-soft:  #E8C8B3;
      --sage:         #7D8F71;

      /* Shared tokens (match v1 names so VersionSwitcher inherits cleanly) */
      --color-bg:      var(--paper);
      --color-surface: var(--paper-2);
      --color-text:    var(--ink);
      --color-text-soft: var(--ink-soft);
      --color-border:  var(--rule);
      --shadow-sm:     0 1px 2px rgba(20, 17, 14, 0.08);

      /* Typography */
      --font-display: 'Fraunces', 'Times New Roman', Georgia, serif;
      --font-body:    'Geist', system-ui, -apple-system, 'Segoe UI', sans-serif;
      --font-mono:    ui-monospace, 'SFMono-Regular', Menlo, monospace;
    }

    :root[data-v="v2"][data-theme="dark"] {
      --paper:        #0E0C09;
      --paper-2:      #191510;
      --ink:          #EDE6D7;
      --ink-soft:     #B8AEA0;
      --ink-faint:    #6B6356;
      --rule:         rgba(237, 230, 215, 0.16);
      --rule-strong:  rgba(237, 230, 215, 0.36);
      --accent:       #E0633E;
      --accent-soft:  #3A2A22;
      --sage:         #8FA27F;
      --shadow-sm:    0 1px 2px rgba(0, 0, 0, 0.6);
    }

    html[data-v="v2"] {
      background: var(--paper);
      color: var(--ink);
    }

    html[data-v="v2"] *,
    html[data-v="v2"] *::before,
    html[data-v="v2"] *::after {
      box-sizing: border-box;
    }

    .v2-body {
      margin: 0;
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.55;
      color: var(--ink);
      background: var(--paper);
      /* Subtle paper grain — pure CSS radial dots */
      background-image:
        radial-gradient(circle at 25% 15%, rgba(20, 17, 14, 0.022) 0 1px, transparent 1.5px),
        radial-gradient(circle at 75% 85%, rgba(20, 17, 14, 0.018) 0 1px, transparent 1.5px);
      background-size: 7px 7px, 11px 11px;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      min-height: 100vh;
    }

    :root[data-v="v2"][data-theme="dark"] .v2-body {
      background-image:
        radial-gradient(circle at 25% 15%, rgba(237, 230, 215, 0.03) 0 1px, transparent 1.5px),
        radial-gradient(circle at 75% 85%, rgba(237, 230, 215, 0.025) 0 1px, transparent 1.5px);
    }

    html[data-v="v2"] a { color: inherit; text-decoration: none; }
    html[data-v="v2"] img { max-width: 100%; display: block; }
    html[data-v="v2"] button { font: inherit; color: inherit; }

    /* Reveal primitives */
    [data-reveal] {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.9s cubic-bezier(0.2, 0.7, 0.2, 1), transform 0.9s cubic-bezier(0.2, 0.7, 0.2, 1);
      will-change: opacity, transform;
    }
    [data-reveal].is-in {
      opacity: 1;
      transform: none;
    }
    @media (prefers-reduced-motion: reduce) {
      [data-reveal] { opacity: 1; transform: none; transition: none; }
    }
  </style>
</body>
</html>
