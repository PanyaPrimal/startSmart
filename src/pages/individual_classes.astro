---
import { getEntry, getEntries } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import RateGrid from '../components/RateGrid.astro';
import FaqList from '../components/FaqList.astro';
import ContactSection from '../components/ContactSection.astro';

const fmt = (await getEntry('formats', 'individual'))!.data;
const others = await getEntries([
  { collection: 'formats', slug: 'pair' },
  { collection: 'formats', slug: 'group' },
]);
const otherRates = others.map((o) => ({
  name: o.data.title,
  price: o.data.priceFrom,
  href: o.data.href,
  btnLabel: 'Детальніше',
}));
---
<BaseLayout title={fmt.shortTitle}>
  <Hero
    title={fmt.title}
    subtitle={fmt.subtitle}
    image={fmt.heroImage}
    overlay={fmt.heroOverlay}
    ctaLabel="Дивитися ціни"
    ctaHref="#rates"
  />
  <RateGrid
    title="ЦІНИ НА КУРСИ"
    note={fmt.ratesNote}
    rates={fmt.rates}
    other={{ title: 'Інші формати навчання', rates: otherRates }}
  />
  <FaqList items={fmt.faq} />
  <ContactSection
    title="ЗВ'ЯЖІТЬСЯ З НАМИ"
    text="Ми завжди раді відповісти на будь-яке запитання! Залишіть заявку нижче або напишіть у месенджер."
    formTitle="ЗАПИС НА УРОК"
    formIdPrefix="ind"
  />
</BaseLayout>
