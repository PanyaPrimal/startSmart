---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Індивідуальні заняття">
  <section class="hero" id="start">
    <div class="hero__bg" style="background-image:url('/images/1111.png'); background-color:#e17088;"></div>
    <div class="hero__overlay" style="background:rgba(225,112,136,0.6);"></div>
    <div class="hero__content container">
      <h1 class="hero__title">ІНДИВІДУАЛЬНІ ЗАНЯТТЯ</h1>
      <p class="hero__subtitle">Ви + викладач / урок 55 хв. Програма адаптується повністю під вас</p>
      <a href="#rates" class="hero__cta">Дивитися ціни</a>
    </div>
  </section>

  <section class="section rates" id="rates">
    <div class="container">
      <h2 class="rates__title">ЦІНИ НА КУРСИ</h2>
      <p class="rates__note">Ціна на навчання з викладачем Світлана</p>
      <div class="rates__grid">
        <div class="rate-card">
          <h3 class="rate-card__name">ПЕРШИЙ УРОК</h3>
          <p class="rate-card__duration">55 хв.</p>
          <p class="rate-card__price">400 грн</p>
          <p class="rate-card__per">за урок</p>
          <a href="#contact" class="rate-card__btn">Записатися</a>
        </div>
        <div class="rate-card rate-card--featured">
          <h3 class="rate-card__name">10 УРОКІВ</h3>
          <p class="rate-card__duration">10 × 55 хв.</p>
          <p class="rate-card__price">3600 грн</p>
          <p class="rate-card__per">пакет / Світлана</p>
          <a href="#contact" class="rate-card__btn">Записатися</a>
        </div>
        <div class="rate-card">
          <h3 class="rate-card__name">10 УРОКІВ</h3>
          <p class="rate-card__duration">10 × 55 хв.</p>
          <p class="rate-card__price">3150 грн</p>
          <p class="rate-card__per">пакет / інші викладачі</p>
          <a href="#contact" class="rate-card__btn">Записатися</a>
        </div>
      </div>
      <div class="rates__other">
        <h3 class="rates__other-title">Інші формати навчання</h3>
        <div class="rates__other-grid">
          <div class="rate-card">
            <h3 class="rate-card__name">ПАРНІ ЗАНЯТТЯ</h3>
            <p class="rate-card__price">від 190 грн / 60 хв.</p>
            <a href="/pair_classes.html" class="rate-card__btn">Детальніше</a>
          </div>
          <div class="rate-card">
            <h3 class="rate-card__name">ГРУПОВІ ЗАНЯТТЯ</h3>
            <p class="rate-card__price">від 150 грн / 80 хв.</p>
            <a href="/group_classes.html" class="rate-card__btn">Детальніше</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--pink-bg faq" id="faq">
    <div class="container">
      <h2 class="faq__title">ЧАСТІ ПИТАННЯ</h2>
      <ul class="faq__list">
        <li class="faq-item">
          <button class="faq-item__question">Чи можна повернути оплату? <span class="faq-item__icon">+</span></button>
          <div class="faq-item__answer">Так, ви можете повернути оплату за невикористані заняття. Зв'яжіться з нами через email або Telegram для уточнення деталей.</div>
        </li>
        <li class="faq-item">
          <button class="faq-item__question">Як проходять заняття? <span class="faq-item__icon">+</span></button>
          <div class="faq-item__answer">Заняття проходять онлайн через Zoom, Skype або Teams. Після оплати ми надішлемо посилання та розклад.</div>
        </li>
        <li class="faq-item">
          <button class="faq-item__question">Як обрати викладача? <span class="faq-item__icon">+</span></button>
          <div class="faq-item__answer">Ми проведемо безкоштовний пробний урок для визначення рівня та підбору найкращого викладача під ваші цілі.</div>
        </li>
      </ul>
    </div>
  </section>

  <section class="section contact" id="contact">
    <div class="container">
      <div class="contact__inner">
        <div class="contact__info">
          <h2 class="contact__title">ЗВ'ЯЖІТЬСЯ З НАМИ</h2>
          <p class="contact__text">Ми завжди раді відповісти на будь-яке запитання! Залишіть заявку нижче або напишіть у месенджер.</p>
          <div class="contact__channels">
            <a href="https://t.me/startsmart_world" class="contact__channel" target="_blank" rel="noopener">
              <img src="/images/telegramm.jpg" alt="Telegram" />
              <span>Telegram</span>
            </a>
            <a href="https://instagram.com/startsmart_world" class="contact__channel" target="_blank" rel="noopener">
              <img src="/images/instagram.jpg" alt="Instagram" />
              <span>Instagram</span>
            </a>
          </div>
        </div>
        <form class="form" action="#" method="post">
          <h3 class="form__title">ЗАПИС НА УРОК</h3>
          <div class="form__group">
            <label class="form__label" for="ind-name">Ваше ім'я</label>
            <input class="form__input" type="text" id="ind-name" name="name" placeholder="Ім'я" required />
          </div>
          <div class="form__group">
            <label class="form__label" for="ind-phone">Телефон або Telegram</label>
            <input class="form__input" type="text" id="ind-phone" name="phone" placeholder="+380..." />
          </div>
          <div class="form__group">
            <label class="form__label" for="ind-msg">Коментар</label>
            <textarea class="form__textarea" id="ind-msg" name="message" placeholder="Рівень, мета, зручний час..."></textarea>
          </div>
          <button class="form__btn" type="submit">Надіслати</button>
          <p class="form__note">Натискаючи кнопку, ви даєте згоду на обробку персональних даних</p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
