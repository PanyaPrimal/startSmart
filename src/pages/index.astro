---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Головна">
  <section class="quick-menu">
    <img class="quick-menu__deco quick-menu__deco--tl" src="/images/GreenHat.png" alt="" aria-hidden="true" />
    <img class="quick-menu__deco quick-menu__deco--tr" src="/images/Hat.png" alt="" aria-hidden="true" />
    <img class="quick-menu__deco quick-menu__deco--bl" src="/images/GreenHat_2.png" alt="" aria-hidden="true" />
    <img class="quick-menu__deco quick-menu__deco--br" src="/images/Hat_2.png" alt="" aria-hidden="true" />
    <h1 class="quick-menu__title">Welcome to StartSmart</h1>
    <div class="quick-menu__grid">
      <a href="/english_school.html" class="quick-menu__btn quick-menu__btn--pink">English School</a>
      <a href="/polish.html" class="quick-menu__btn quick-menu__btn--teal">Szkoła Językowa</a>
      <a href="https://t.me/startsmart_world" class="quick-menu__btn quick-menu__btn--teal" target="_blank" rel="noopener">Telegram</a>
      <a href="https://instagram.com/startsmart_world" class="quick-menu__btn quick-menu__btn--pink" target="_blank" rel="noopener">Instagram</a>
    </div>
