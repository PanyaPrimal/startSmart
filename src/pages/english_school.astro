---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import MethodGrid from '../components/MethodGrid.astro';
import RateGrid from '../components/RateGrid.astro';
import TeacherGrid from '../components/TeacherGrid.astro';
import FaqList from '../components/FaqList.astro';
import ContactSection from '../components/ContactSection.astro';
import { url } from '../utils/url';

const page = (await getEntry('pages', 'english_school'))!.data;
---
<BaseLayout title={page.title}>
  {page.hero && (
    <Hero
      title={page.hero.title}
      subtitle={page.hero.subtitle}
      image={page.hero.image}
      overlay={page.hero.overlay}
      ctaLabel={page.hero.ctaLabel}
      ctaHref={page.hero.ctaHref}
    />
  )}

  {page.about && (
    <section class="section about" id="about">
      <div class="container">
        <div class="about__inner">
          <div class="about__content">
            {page.about.label && <p class="about__label">{page.about.label}</p>}
            <h2 class="about__title">{page.about.title}</h2>
            {page.about.paragraphs.map((p) => <p class="about__text">{p}</p>)}
          </div>
          {page.about.image && (
            <div class="about__image">
              <img src={url(page.about.image.src)} alt={page.about.image.alt || ''} />
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  {page.features && (
    <section class="section section--pink-bg features" id="courses">
      <div class="container">
        <h2 class="features__title">{page.features.title}</h2>
        <div class="features__grid">
          {page.features.items.map((f) => (
            <div class="feature-card">
              <div class="feature-card__icon">{f.icon}</div>
              <p class="feature-card__title">{f.title}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.methods.length > 0 && (
    <MethodGrid title={page.methodsTitle} formats={page.methods} />
  )}

  {page.rates.length > 0 && <RateGrid title={page.ratesTitle} rates={page.rates} />}

  {page.teachers.length > 0 && (
    <TeacherGrid title={page.teachersTitle} teachers={page.teachers} />
  )}

  {page.faq.length > 0 && <FaqList title={page.faqTitle} items={page.faq} id="questions" />}

  {page.contact && (
    <ContactSection
      title={page.contact.title}
      text={page.contact.text}
      formTitle={page.contact.formTitle}
      formIdPrefix="es"
      showEmail
      id="contacts"
    />
  )}
</BaseLayout>
