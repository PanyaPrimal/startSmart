---
import { getEntry, getCollection } from 'astro:content';
import V2Layout from '../../layouts/V2Layout.astro';
import { url } from '../../utils/url';

const settings = (await getEntry('settings', 'site'))!.data;
const english = (await getEntry('pages', 'english_school'))!.data;

const formats = (await getCollection('formats')).sort((a, b) => a.data.order - b.data.order);
const teachers = (await getCollection('teachers')).sort((a, b) => a.data.order - b.data.order);

const year = new Date().getFullYear();
const issueNumber = 'Nº 002';

// Pull quote source — grab Svitlana's quote if present, fall back to first quoted teacher
const quoteTeacher = teachers.find((t) => t.id === 'svitlana') ?? teachers.find((t) => t.data.quote);
const pullQuote = quoteTeacher?.data.quote?.replace(/^"|"$/g, '').replace(/^"|"$/g, '');
const pullQuoteAuthor = quoteTeacher?.data.name;

const languageLabels: Record<string, string> = {
  english: 'EN',
  polish: 'PL',
  ukrainian: 'UA',
  russian: 'RU',
};
---
<V2Layout title="StartSmart — Мовна студія" description={settings.tagline}>
  <!-- =========================================================
       MASTHEAD — magazine header
       ========================================================= -->
  <header class="masthead">
    <div class="masthead__bar">
      <span class="masthead__issue">{issueNumber}</span>
      <span class="masthead__sep" aria-hidden="true">·</span>
      <span class="masthead__place">Poltava / Online</span>
      <span class="masthead__sep" aria-hidden="true">·</span>
      <span class="masthead__year">{year}</span>
      <span class="masthead__spacer"></span>
      <button id="v2ThemeToggle" class="masthead__theme" type="button" aria-label="Перемкнути тему">
        <span class="theme-dot" aria-hidden="true"></span>
        <span class="theme-label">тема</span>
      </button>
    </div>
    <div class="masthead__title-row">
      <a href={url('/v2.html')} class="masthead__title">
        <span class="masthead__title-main">StartSmart</span>
        <span class="masthead__title-sub">— Мовна студія</span>
      </a>
      <nav class="masthead__nav" aria-label="Основна навігація">
        <a href="#manifesto">Манiфест</a>
        <a href="#formats">Формати</a>
        <a href="#teachers">Викладачі</a>
        <a href="#questions">Питання</a>
        <a href="#contact" class="masthead__nav-cta">Запис →</a>
      </nav>
    </div>
    <hr class="rule rule--double" />
  </header>

  <!-- =========================================================
       HERO — oversized editorial display
       ========================================================= -->
  <section class="hero">
    <div class="hero__grid">
      <div class="hero__kicker" data-reveal>
        <span class="kicker__num">Nº 001</span>
        <span class="kicker__dot" aria-hidden="true">●</span>
        <span class="kicker__label">Мови у власному темпі</span>
      </div>

      <h1 class="hero__headline" data-reveal>
        Говори<span class="hero__amp">&nbsp;&amp;&nbsp;</span>живи<br />
        <em class="hero__em">мовою</em>, що
        <span class="hero__underline">обираєш</span>.
      </h1>

      <p class="hero__lede" data-reveal>
        StartSmart — мовна студія з Полтави. Вчимо англійської та польської
        так, як вчили б близького друга: без муштри, з увагою до живого
        спілкування та повагою до твого часу.
      </p>

      <div class="hero__meta" data-reveal>
        <a href="#contact" class="btn btn--primary">
          <span>Безкоштовний пробний урок</span>
          <span class="btn__arrow" aria-hidden="true">→</span>
        </a>
        <div class="hero__stats">
          <div class="stat">
            <span class="stat__num">5</span>
            <span class="stat__label">Викладачів<br />рівня C1–C2</span>
          </div>
          <div class="stat">
            <span class="stat__num">3</span>
            <span class="stat__label">Формати<br />навчання</span>
          </div>
          <div class="stat">
            <span class="stat__num">2</span>
            <span class="stat__label">Мови<br />EN · PL</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- =========================================================
       MARQUEE — languages ticker
       ========================================================= -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      <span>English</span><span class="marquee__dot">✦</span>
      <span>Polski</span><span class="marquee__dot">✦</span>
      <span>Українська</span><span class="marquee__dot">✦</span>
      <span>C1 · C2</span><span class="marquee__dot">✦</span>
      <span>Live</span><span class="marquee__dot">✦</span>
      <span>Online</span><span class="marquee__dot">✦</span>
      <span>English</span><span class="marquee__dot">✦</span>
      <span>Polski</span><span class="marquee__dot">✦</span>
      <span>Українська</span><span class="marquee__dot">✦</span>
      <span>C1 · C2</span><span class="marquee__dot">✦</span>
      <span>Live</span><span class="marquee__dot">✦</span>
      <span>Online</span><span class="marquee__dot">✦</span>
    </div>
  </div>

  <hr class="rule" />

  <!-- =========================================================
       MANIFESTO — pulled from english_school "about"
       ========================================================= -->
  <section id="manifesto" class="section section--manifesto">
    <div class="section__head" data-reveal>
      <span class="section__num">Nº 02</span>
      <span class="section__kicker">Манiфест</span>
    </div>
    <div class="manifesto__grid">
      <h2 class="section__title" data-reveal>
        Не курс. <em>Щоденна практика</em> — з тими, хто вже живе мовою.
      </h2>
      <div class="manifesto__body" data-reveal>
        {english.about?.paragraphs.slice(0, 2).map((p) => <p>{p}</p>)}
      </div>
      <ul class="manifesto__features" data-reveal>
        {english.features?.items.slice(0, 5).map((f, i) => (
          <li>
            <span class="feature__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="feature__text">{f.title}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <hr class="rule" />

  <!-- =========================================================
       PULL QUOTE — editorial callout
       ========================================================= -->
  {pullQuote && (
    <section class="pullquote" data-reveal>
      <span class="pullquote__mark" aria-hidden="true">“</span>
      <blockquote>
        <p>{pullQuote}</p>
        <cite>— {pullQuoteAuthor}, засновниця</cite>
      </blockquote>
    </section>
  )}

  <hr class="rule" />

  <!-- =========================================================
       FORMATS — editorial features
       ========================================================= -->
  <section id="formats" class="section section--formats">
    <div class="section__head" data-reveal>
      <span class="section__num">Nº 03</span>
      <span class="section__kicker">Формати навчання</span>
    </div>
    <h2 class="section__title" data-reveal>
      Три способи <em>зустрітися</em> з мовою.
    </h2>

    <div class="formats">
      {formats.map((fmt, i) => {
        const d = fmt.data;
        return (
          <article class="format" data-reveal>
            <div class="format__num">{String(i + 1).padStart(2, '0')}</div>
            <div class="format__body">
              <h3 class="format__title">{d.title}</h3>
              <p class="format__subtitle">{d.subtitle}</p>
              <div class="format__meta">
                <span class="format__price">{d.priceFrom}</span>
                <a href="#contact" class="format__cta">
                  Записатися <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    {formats[0] && (
      <p class="section__note">{formats[0].data.ratesNote}</p>
    )}
  </section>

  <hr class="rule" />

  <!-- =========================================================
       TEACHERS — editorial portraits
       ========================================================= -->
  <section id="teachers" class="section section--teachers">
    <div class="section__head" data-reveal>
      <span class="section__num">Nº 04</span>
      <span class="section__kicker">Склад редакції</span>
    </div>
    <h2 class="section__title" data-reveal>
      Твої <em>викладачі</em>.
    </h2>

    <div class="teachers">
      {teachers.map((t) => {
        const d = t.data;
        const langs = d.languages.map((l) => languageLabels[l]).filter(Boolean);
        return (
          <article class="teacher" data-reveal>
            <div class="teacher__portrait">
              <img src={url(d.photo.src)} alt={d.photo.alt || d.name} loading="lazy" />
              <div class="teacher__langs">
                {langs.map((l) => <span>{l}</span>)}
              </div>
            </div>
            <h3 class="teacher__name">{d.name}</h3>
            <p class="teacher__info">{d.info}</p>
          </article>
        );
      })}
    </div>
  </section>

  <hr class="rule" />

  <!-- =========================================================
       FAQ — large-type accordion
       ========================================================= -->
  <section id="questions" class="section section--faq">
    <div class="section__head" data-reveal>
      <span class="section__num">Nº 05</span>
      <span class="section__kicker">Питання</span>
    </div>
    <h2 class="section__title" data-reveal>
      Що варто <em>знати</em> перед початком.
    </h2>

    <div class="faq" data-accordion>
      {english.faq.map((item, i) => (
        <div class="faq__item" data-accordion-item>
          <button class="faq__trigger" data-accordion-trigger type="button">
            <span class="faq__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="faq__q">{item.question}</span>
            <span class="faq__toggle" aria-hidden="true">+</span>
          </button>
          <div class="faq__answer">
            <p>{item.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <hr class="rule" />

  <!-- =========================================================
       CONTACT
       ========================================================= -->
  <section id="contact" class="section section--contact">
    <div class="section__head" data-reveal>
      <span class="section__num">Nº 06</span>
      <span class="section__kicker">Зв'язок</span>
    </div>

    <div class="contact" data-reveal>
      <h2 class="contact__title">
        Напиши — <em>відповімо</em> того ж дня.
      </h2>
      <p class="contact__text">{english.contact?.text}</p>

      <div class="contact__channels">
        <a class="channel" href={`mailto:${settings.email}`}>
          <span class="channel__label">Email</span>
          <span class="channel__value">{settings.email}</span>
          <span class="channel__arrow" aria-hidden="true">→</span>
        </a>
        {settings.socials.telegram && (
          <a class="channel" href={settings.socials.telegram} target="_blank" rel="noopener">
            <span class="channel__label">Telegram</span>
            <span class="channel__value">@startsmart_world</span>
            <span class="channel__arrow" aria-hidden="true">→</span>
          </a>
        )}
        {settings.socials.instagram && (
          <a class="channel" href={settings.socials.instagram} target="_blank" rel="noopener">
            <span class="channel__label">Instagram</span>
            <span class="channel__value">@startsmart_world</span>
            <span class="channel__arrow" aria-hidden="true">→</span>
          </a>
        )}
      </div>
    </div>
  </section>

  <hr class="rule rule--double" />

  <!-- =========================================================
       COLOPHON / footer
       ========================================================= -->
  <footer class="colophon">
    <div class="colophon__row">
      <div class="colophon__brand">
        <span class="colophon__brand-main">StartSmart</span>
        <span class="colophon__brand-sub">— Мовна студія · Полтава / Online</span>
      </div>
      <div class="colophon__set-in">
        Set in <em>Fraunces</em> &amp; <em>Geist</em>
      </div>
    </div>
    <div class="colophon__row colophon__row--fine">
      <span>{settings.footerCopy}</span>
      <span>{issueNumber} / {year}</span>
    </div>
  </footer>
</V2Layout>

<style>
  /* ============================================================
     Layout container
     ============================================================ */
  .masthead,
  .hero,
  .section,
  .pullquote,
  .colophon {
    max-width: 1240px;
    margin: 0 auto;
    padding-left: 22px;
    padding-right: 22px;
  }

  @media (min-width: 768px) {
    .masthead, .hero, .section, .pullquote, .colophon {
      padding-left: 40px;
      padding-right: 40px;
    }
  }
  @media (min-width: 1080px) {
    .masthead, .hero, .section, .pullquote, .colophon {
      padding-left: 64px;
      padding-right: 64px;
    }
  }

  .rule {
    max-width: 1240px;
    margin: 0 auto;
    border: 0;
    border-top: 1px solid var(--rule);
    height: 0;
  }
  .rule--double {
    border-top: 1px solid var(--rule-strong);
    position: relative;
  }
  .rule--double::after {
    content: "";
    display: block;
    border-top: 1px solid var(--rule-strong);
    margin-top: 3px;
  }

  /* ============================================================
     Masthead
     ============================================================ */
  .masthead {
    padding-top: 16px;
    padding-bottom: 8px;
  }
  .masthead__bar {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    padding-bottom: 12px;
    border-bottom: 1px solid var(--rule);
  }
  .masthead__spacer { flex: 1; }
  .masthead__sep { opacity: 0.5; }
  .masthead__theme {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border: 1px solid var(--rule);
    border-radius: 999px;
    background: transparent;
    cursor: pointer;
    color: inherit;
    font: inherit;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: border-color 0.2s, background 0.2s;
  }
  .masthead__theme:hover { border-color: var(--rule-strong); background: var(--paper-2); }
  .theme-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--ink);
    box-shadow: inset 0 0 0 1px var(--paper);
  }

  .masthead__title-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    padding: 22px 0 20px;
    flex-wrap: wrap;
  }
  .masthead__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-optical-sizing: auto;
    font-variation-settings: "SOFT" 30;
    font-size: clamp(32px, 7vw, 54px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .masthead__title-sub {
    font-style: italic;
    font-weight: 300;
    color: var(--ink-soft);
    font-size: 0.5em;
    margin-left: 0.15em;
    white-space: nowrap;
  }
  .masthead__nav {
    display: none;
    gap: 26px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding-bottom: 8px;
  }
  @media (min-width: 880px) {
    .masthead__nav { display: inline-flex; }
  }
  .masthead__nav a {
    position: relative;
    transition: color 0.2s;
  }
  .masthead__nav a::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -4px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.35s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .masthead__nav a:hover::after { transform: scaleX(1); transform-origin: left; }
  .masthead__nav-cta {
    color: var(--accent);
    font-weight: 600;
  }

  /* ============================================================
     Hero
     ============================================================ */
  .hero {
    padding-top: clamp(32px, 6vw, 72px);
    padding-bottom: clamp(48px, 8vw, 120px);
  }
  .hero__grid {
    display: grid;
    gap: 28px;
  }
  .hero__kicker {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .kicker__num { color: var(--accent); font-weight: 600; }
  .kicker__dot { color: var(--accent); font-size: 8px; }

  .hero__headline {
    font-family: var(--font-display);
    font-weight: 300;
    font-variation-settings: "SOFT" 50, "opsz" 144;
    font-size: clamp(52px, 11.5vw, 168px);
    line-height: 0.88;
    letter-spacing: -0.035em;
    color: var(--ink);
    margin: 0;
    max-width: 14ch;
  }
  .hero__em {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 80, "opsz" 144;
    color: var(--accent);
    display: inline-block;
  }
  .hero__amp {
    font-style: italic;
    font-weight: 300;
    color: var(--ink-soft);
    font-size: 0.6em;
    vertical-align: 0.12em;
  }
  .hero__underline {
    position: relative;
    white-space: nowrap;
  }
  .hero__underline::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: 0.08em;
    height: 0.08em;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    animation: underline-draw 1.2s 0.9s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
  }
  @keyframes underline-draw {
    to { transform: scaleX(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__underline::after { transform: scaleX(1); animation: none; }
  }

  .hero__lede {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.6vw, 19px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 48ch;
    margin: 12px 0 0;
  }

  .hero__meta {
    display: flex;
    flex-direction: column;
    gap: 28px;
    margin-top: 12px;
  }
  @media (min-width: 768px) {
    .hero__meta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 16px 26px;
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: transform 0.25s, background 0.25s, color 0.25s;
    cursor: pointer;
    border: 1px solid transparent;
  }
  .btn--primary {
    background: var(--ink);
    color: var(--paper);
  }
  .btn--primary:hover {
    background: var(--accent);
    transform: translateY(-1px);
  }
  .btn__arrow {
    font-size: 1.2em;
    transition: transform 0.25s;
  }
  .btn:hover .btn__arrow { transform: translateX(4px); }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    padding-top: 14px;
    border-top: 1px solid var(--rule);
    max-width: 440px;
  }
  .stat__num {
    display: block;
    font-family: var(--font-display);
    font-variation-settings: "SOFT" 40, "opsz" 144;
    font-weight: 400;
    font-size: clamp(36px, 5vw, 54px);
    line-height: 1;
    color: var(--accent);
  }
  .stat__label {
    display: block;
    margin-top: 8px;
    font-size: 11px;
    line-height: 1.35;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-family: var(--font-mono);
  }

  /* ============================================================
     Marquee
     ============================================================ */
  .marquee {
    overflow: hidden;
    padding: 22px 0;
    font-family: var(--font-display);
    font-variation-settings: "SOFT" 40;
    font-weight: 300;
    font-size: clamp(34px, 6vw, 64px);
    line-height: 1;
    color: var(--ink);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .marquee__track {
    display: inline-flex;
    gap: 32px;
    white-space: nowrap;
    animation: marquee 42s linear infinite;
  }
  .marquee__dot {
    color: var(--accent);
    font-style: normal;
    font-size: 0.6em;
    align-self: center;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee__track { animation: none; }
  }

  /* ============================================================
     Section primitives
     ============================================================ */
  .section {
    padding-top: clamp(56px, 8vw, 112px);
    padding-bottom: clamp(56px, 8vw, 112px);
  }
  .section__head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding-bottom: 28px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .section__num {
    color: var(--accent);
    font-weight: 600;
  }
  .section__title {
    font-family: var(--font-display);
    font-weight: 300;
    font-variation-settings: "SOFT" 30, "opsz" 144;
    font-size: clamp(36px, 6vw, 88px);
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0;
    max-width: 20ch;
  }
  .section__title em {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 80, "opsz" 144;
    color: var(--accent);
  }
  .section__note {
    margin-top: 32px;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    font-family: var(--font-mono);
    text-transform: uppercase;
  }

  /* ============================================================
     Manifesto
     ============================================================ */
  .manifesto__grid {
    display: grid;
    gap: 32px;
