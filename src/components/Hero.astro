---
import { url } from '../utils/url';
interface Props {
  title: string;
  subtitle?: string;
  image?: { src: string; alt?: string };
  overlay?: 'pink' | 'teal' | 'dark';
  ctaLabel?: string;
  ctaHref?: string;
}
const { title, subtitle, image, overlay = 'pink', ctaLabel, ctaHref } = Astro.props;
---
<section class={`hero hero--overlay-${overlay}`} id="start">
  {image && <div class="hero__bg" style={`background-image:url('${url(image.src)}');`}></div>}
  <div class="hero__overlay"></div>
  <div class="hero__content container">
    <h1 class="hero__title">{title}</h1>
    {subtitle && <p class="hero__subtitle">{subtitle}</p>}
    {ctaLabel && ctaHref && <a href={url(ctaHref)} class="hero__cta">{ctaLabel}</a>}
  </div>
</section>
