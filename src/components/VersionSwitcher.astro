---
// Список версий сайта. Добавляй сюда новые редизайны.
const base = import.meta.env.BASE_URL;
const versions = [
  { value: base,                     label: 'v1 — Astro (поточна)' },
  { value: `${base}legacy/index.html`, label: 'v0 — Оригінал' },
  // { value: `${base}v2/`,          label: 'v2 — Новий дизайн' },
];
---
<div class="version-switcher">
  <label class="version-switcher__label" for="versionSelect">Версія:</label>
  <select id="versionSelect" class="version-switcher__select">
    {versions.map(v => (
      <option value={v.value}>{v.label}</option>
    ))}
  </select>
</div>

<script is:inline>
  (function () {
    const select = document.getElementById('versionSelect');
    if (!select) return;

    // The first option is the base (current Astro version). Any option whose
    // value isn't just the base and whose prefix matches the current path wins.
    const path = window.location.pathname;
    const baseValue = select.options[0] ? select.options[0].value : '/';
    let current = baseValue;
    for (const opt of select.options) {
      if (opt.value === baseValue) continue;
      const prefix = opt.value.replace(/index\.html$/, '');
      if (path.startsWith(prefix)) {
        current = opt.value;
        break;
      }
    }
    select.value = current;

    select.addEventListener('change', (e) => {
      window.location.href = e.target.value;
    });
  })();
</script>

<style>
  .version-switcher {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 90;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    font-size: 13px;
    opacity: 0.85;
    transition: opacity 0.2s ease, background-color 0.25s ease, border-color 0.25s ease;
  }
  .version-switcher:hover {
    opacity: 1;
  }
  .version-switcher__label {
    color: var(--color-text-soft);
  }
  .version-switcher__select {
    padding: 2px 4px;
    border: none;
    background: transparent;
    color: var(--color-text);
    font: inherit;
    cursor: pointer;
  }
  .version-switcher__select:focus {
    outline: none;
  }
</style>
