---
import { getEntry } from 'astro:content';
import { url } from '../utils/url';
const s = (await getEntry('settings', 'site'))!.data;
---
<footer class="layout__footer footer">
  <div class="container">
    <div class="footer__inner">
      <a href={url('/')} class="footer__logo">{s.siteName}</a>
      <p class="footer__copy">{s.footerCopy} <a href={`mailto:${s.email}`}>{s.email}</a></p>
      <div class="footer__socials">
        {s.socials.facebook && (
          <a href={s.socials.facebook} class="footer__social-link" target="_blank" aria-label="Facebook">
            <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        )}
        {s.socials.telegram && (
          <a href={s.socials.telegram} class="footer__social-link" target="_blank" aria-label="Telegram">
            <svg viewBox="0 0 24 24"><path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/></svg>
          </a>
        )}
        {s.socials.instagram && (
          <a href={s.socials.instagram} class="footer__social-link" target="_blank" aria-label="Instagram">
            <svg viewBox="0 0 24 24" stroke="white" stroke-width="2" fill="none"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/></svg>
          </a>
        )}
      </div>
    </div>
  </div>
</footer>
